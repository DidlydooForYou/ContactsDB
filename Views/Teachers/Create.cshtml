@model Models.Teacher

@{
    ViewBag.Title = "Prof - Ajout";
}

<div style="width:380px; margin:0 auto; font-family:Arial;">

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <input type="hidden" name="Id" value="@Model.Id" />


        <div style="border:1px solid #dcdcdc; border-radius:6px; padding:5px;">

            <div onclick="toggleProfDetails()"
                 style="background:#d0d0d0; padding:8px; font-weight:bold; cursor:pointer; border-radius:4px;">

                <span id="arrowEdit">▼</span>
                <span>Informations - [@Model.Code]</span>

            </div>

            <div id="editProfDetails">

                <div style="padding:15px;">

                    <div style="margin-bottom:15px;">
                        <label style="font-weight:bold; color:#666;">
                            Prénom
                        </label>

                        @Html.TextBoxFor(model => model.FirstName,
                        new
                        {
                            @class = "form-control"
                        })
                    </div>

                    <div style="margin-bottom:15px;">
                        <label style="font-weight:bold; color:#666;">
                            Nom
                        </label>

                        @Html.TextBoxFor(model => model.LastName,
                        new
                        {
                            @class = "form-control"
                        })
                    </div>

                    <div style="margin-bottom:15px;">
                        <label style="font-weight:bold; color:#666;">
                            Date d'embauche
                        </label>

                        @Html.TextBoxFor(model => model.StartDate,
                        "{0:yyyy-MM-dd}",
                        new
                        {
                            @class = "form-control",
                            type = "date"
                        })
                    </div>

                    <div style="margin-bottom:15px;">
                        <label style="font-weight:bold; color:#666;">
                            Téléphone
                        </label>

                        @Html.TextBoxFor(model => model.Phone,
                        new
                        {
                            @class = "form-control"
                        })
                    </div>

                    <div style="margin-bottom:10px;">

                        <label style="font-weight:bold; color:#666;">
                            Avatar
                        </label>

                        <div class='imageUploader'
                             controlId='Avatar'
                             imageSrc='/App_Assets/Teachers/no_avatar.png'
                             title='Cliquez pour choisir une image'>
                        </div>

                        <span class="field-validation-valid text-danger"
                              data-valmsg-for="Avatar"
                              data-valmsg-replace="true">
                        </span>

                    </div>

                </div>

            </div>

        </div>
    }
</div>

<script>
    function toggleProfDetails() {

        let details = document.getElementById("editProfDetails");
        let arrow = document.getElementById("arrowEdit");

        if (details.style.display === "none") {

            details.style.display = "block";
            arrow.innerHTML = "▼";

        }
        else {

            details.style.display = "none";
            arrow.innerHTML = "►";
        }
    }
</script>